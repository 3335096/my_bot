TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_agent

APP_NAME=telegram-openrouter-agent
APP_URL=
APP_ENV=dev
APP_LOG_LEVEL=INFO

MODEL_GENERAL=openai/gpt-4o-mini
MODEL_CODING=openai/gpt-4.1
MODEL_TRANSLATION=openai/gpt-4o-mini
MODEL_RESEARCH=openai/gpt-4.1
MODEL_VISION=openai/gpt-4o-mini
MODEL_AUDIO=openai/gpt-4o-audio-preview

RECENT_SESSIONS_LIMIT=10
SAVED_SESSIONS_LIMIT=50
MAX_CONTEXT_MESSAGES=16
REQUEST_TIMEOUT_SECONDS=60
WEB_MAX_RESULTS=5
