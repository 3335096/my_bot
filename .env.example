TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_agent

APP_NAME=telegram-openrouter-agent
APP_URL=
APP_ENV=dev
APP_LOG_LEVEL=INFO

# ─── Модели (OpenRouter model IDs) ───────────────────────────────────────────
# Полный список: https://openrouter.ai/models
# Формат: provider/model-name

# Общий диалог — быстрая и дешёвая модель
# Альтернативы: openai/gpt-4o-mini, openai/gpt-4.1-mini
MODEL_GENERAL=google/gemini-2.0-flash

# Код и программирование — сильная reasoning-модель
# Альтернативы: deepseek/deepseek-r1 (бесплатно), openai/gpt-4.1, anthropic/claude-opus-4-5
MODEL_CODING=anthropic/claude-sonnet-4-5

# Перевод — быстрая многоязычная модель
# Альтернативы: openai/gpt-4o-mini, openai/gpt-4.1-mini
MODEL_TRANSLATION=google/gemini-2.0-flash

# Deep research — модель с глубоким reasoning и большим контекстом
# Альтернативы: openai/gpt-4.1, openai/o3-mini, google/gemini-2.0-pro
MODEL_RESEARCH=anthropic/claude-sonnet-4-5

# Web-поиск — быстрая модель для актуальных данных (использует openrouter:web_search)
# Альтернативы: openai/gpt-4o-mini, openai/gpt-4.1-mini
MODEL_WEB=google/gemini-2.0-flash

# Анализ изображений — vision-capable модель
# Альтернативы: google/gemini-2.0-flash, anthropic/claude-sonnet-4-5
MODEL_VISION=openai/gpt-4o

# Транскрибация аудио — STT через input_audio API
# Примечание: не все модели поддерживают input_audio, менять осторожно
MODEL_AUDIO=openai/gpt-4o-audio-preview

# ─── Лимиты и параметры ──────────────────────────────────────────────────────

RECENT_SESSIONS_LIMIT=10
SAVED_SESSIONS_LIMIT=50
MAX_CONTEXT_MESSAGES=16

# Таймаут и retry для запросов к OpenRouter
REQUEST_TIMEOUT_SECONDS=60
REQUEST_MAX_RETRIES=2
REQUEST_RETRY_BACKOFF_BASE_SECONDS=1
REQUEST_RETRY_BACKOFF_MAX_SECONDS=8

# Максимальное количество результатов web-поиска
WEB_MAX_RESULTS=5

# Лимиты аудио
AUDIO_MAX_DURATION_SECONDS=300
AUDIO_MAX_FILE_SIZE_MB=20

# Лимиты документов (PDF и текстовые файлы)
DOCUMENT_MAX_FILE_SIZE_MB=20
DOCUMENT_MAX_EXTRACTED_CHARS=50000
